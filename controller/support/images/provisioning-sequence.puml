@startuml
!include ../../../images/common-sequence.iuml

title Client Provisioning — Controller SoftAP Flow

actor User

box "Client Device\n(ESP8266)"
    participant "Client\nFirmware" as Client
end box

box "Controller (ESP32)"
    participant "SoftAP\n(FireFly-Provisioning)" as AP
    participant "HTTP API" as API
end box

User -> API++ : PUT /api/provisioning\n(visual-token)
API -> AP : start SoftAP\nWPA2 password = nibble-interleave(BSSID)\nTX power = 2 dBm\nmax clients = 1
API --> User-- : 202 Accepted

Client -> Client : scan for SSID\n"FireFly-Provisioning" (exact)
Client -> Client : read BSSID from scan result\ncompute password = nibble-interleave(BSSID)\nreduce TX power to minimum
Client -> AP++ : connect WPA2\nusing derived password
AP -> AP : verify MAC in allowlist

alt MAC not in allowlist
    AP -> API : rogue client event
    API -> AP : shut down SoftAP
    AP --> Client-- : disconnect
else MAC allowed
    AP --> Client-- : connected (DHCP 192.168.4.x)

    Client -> API++ : GET /api/provisioning/nonce\n(no auth)
    API --> Client-- : 200 { "nonce": 3819273645 }

    Client -> API++ : GET /api/provisioning/client\nmac-address: aa:bb:cc:dd:ee:ff\nx-nonce: 3819273645
    API -> API : validate nonce (unused, matches session)
    API -> API : find client record by MAC
    API -> API : invalidate nonce
    API --> Client-- : 200 { full client config JSON }

    Client -> Client : store config to EEPROM\n(WiFi, MQTT, HID, UUID)
    Client -> Client : reboot into normal mode
end

User -> API++ : DELETE /api/provisioning\n(visual-token)
API -> AP : shut down SoftAP
API --> User-- : 202 Accepted

@enduml
