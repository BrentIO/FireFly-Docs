@startuml
!include ../../../images/common-sequence.iuml

title GET /firmware (list)

actor Client

box "AWS" #ffdbbb
    participant "API Gateway" as APIGW
    participant "func-api-firmware-get" as Lambda
    database DynamoDB
end box

Client -> APIGW++ : GET /firmware[?product_hex=...][&version=...]
APIGW -> Lambda++ : invoke

alt no query filters
    Lambda -> DynamoDB++ : Scan (all items)
    DynamoDB --> Lambda-- : items[]
else filtered by product_hex
    Lambda -> DynamoDB++ : Query GSI product_hex-index\nKeyCondition: product_hex = "{product_hex}"
    DynamoDB --> Lambda-- : items[]
else filtered by product_hex and version
    Lambda -> DynamoDB++ : Query GSI product_hex-index\nKeyCondition: product_hex = "{product_hex}"\nFilterExpression: version = "{version}"
    DynamoDB --> Lambda-- : items[] (may contain multiple builds)
end

note right of Lambda
    files[] and pk are excluded from list responses.
    Use GET /firmware/{zip_name} for the full record.
end note

Lambda --> APIGW-- : 200 OK\n{"items": [...]}
APIGW --> Client-- : 200 OK\n{"items": [...]}

@enduml
