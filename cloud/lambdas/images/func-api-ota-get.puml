@startuml
!include ../../../images/common-sequence.iuml

title GET /ota/{class}/{product_hex}

actor Controller

box "AWS" #ffdbbb
    participant "API Gateway" as APIGW
    participant "func-api-ota-get" as Lambda
    database DynamoDB
    collections "CloudFront" as CF
end box

Controller -> APIGW++ : GET /ota/{class}/{product_hex}\n?current_version={version}
APIGW -> Lambda++ : invoke

alt missing current_version param
    Lambda --> APIGW-- : 400 Bad Request
    APIGW --> Controller-- : 400 Bad Request
else current_version provided
    Lambda -> DynamoDB++ : Query pk = {class}#{product_hex}\nfilter release_status = RELEASED
    alt no released firmware found
        DynamoDB --> Lambda-- : (no items)
        Lambda --> APIGW-- : 404 Not Found
        APIGW --> Controller-- : 404 Not Found
    else current version is revoked or unknown with no newer release
        DynamoDB --> Lambda-- : items (current_version not in RELEASED,\nno newer RELEASED version exists)
        Lambda --> APIGW-- : 409 Conflict
        APIGW --> Controller-- : 409 Conflict
    else update available
        DynamoDB --> Lambda-- : items (released builds)
        Lambda -> Lambda : find oldest RELEASED with version > current_version\nbuild CloudFront URLs from main_binary + www.bin
        Lambda --> APIGW-- : 200 OK\n{"type": "...", "version": "{next}", "url": "...", "littlefs": "..."}
        APIGW --> Controller-- : 200 OK\n{OTA manifest — next version}
        Controller -> CF++ : GET /{class}/{product_hex}/{version}/{binary}
        CF --> Controller-- : firmware binary
    else already on latest released version
        DynamoDB --> Lambda-- : items (current_version found in RELEASED,\nno newer version exists)
        Lambda -> Lambda : build CloudFront URLs for current version
        Lambda --> APIGW-- : 200 OK\n{"type": "...", "version": "{same}", "url": "...", "littlefs": "..."}
        APIGW --> Controller-- : 200 OK\n{OTA manifest — same version, semver_compare == 0, no update}
    end
end

@enduml
