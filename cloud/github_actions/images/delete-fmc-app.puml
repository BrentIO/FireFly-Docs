@startuml
!include ../../../images/common-sequence.iuml

title delete-fmc-app\n(GitHub Action → S3)

actor "GitHub Actions Runner" as GHA

box "AWS" #ffdbbb
    participant "CloudFormation / SAM" as CF
    participant "S3" as S3
end box

GHA -> S3++ : aws s3 rm s3://{S3_FMC_BUCKET_NAME}\n--recursive
S3 --> GHA-- : Objects deleted

alt Bucket does not exist
    S3 --> GHA : NoSuchBucket
    note over GHA : Workflow exits 0 (idempotent)
end

@enduml
