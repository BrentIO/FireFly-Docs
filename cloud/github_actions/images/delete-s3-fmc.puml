@startuml
!include ../../../images/common-sequence.iuml

title delete-s3-fmc\n(GitHub Action → CloudFormation)

actor "GitHub Actions Runner" as GHA

box "AWS" #ffdbbb
    participant "CloudFormation / SAM" as CF
    collections "S3" as S3
end box

note over GHA : Prerequisite: delete-cloudfront-fmc must\ncomplete before this job runs\n(which requires delete-fmc-app first).

GHA -> S3 : Delete all objects (recursive)
S3 --> GHA : Bucket empty

GHA -> CF++ : sam delete\nstack: firefly-s3-fmc\n--no-prompts --region
CF -> S3 : Delete bucket
S3 --> CF : Bucket deleted
CF --> GHA-- : DELETE_COMPLETE

alt Stack does not exist
    CF --> GHA : Stack not found
    note over GHA : Workflow exits 0 (idempotent)
end

alt Bucket non-empty at stack deletion time
    CF --> GHA : DELETE_FAILED
    note over GHA : Workflow fails if pre-deletion\nbucket empty step is skipped.\nScript empties bucket before sam delete.
end

@enduml
